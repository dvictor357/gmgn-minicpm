# OpenAI-compatible endpoint that serves MiniCPM5-1B.
# Default = llama.cpp llama-server (verified on Apple Silicon; scripts/serve-llamacpp.sh).
# For SGLang on CUDA, use http://127.0.0.1:30000/v1 instead.
SGLANG_BASE_URL=http://127.0.0.1:8080/v1

# Model id as registered by the server.
# llama.cpp reports the -hf repo id; SGLang uses the model path.
GMGN_LOCAL_MODEL=openbmb/MiniCPM5-1B-GGUF

# Path/name of the gmgn-cli binary (must already be configured: `gmgn-cli config --check` == 0).
GMGN_CLI_BIN=gmgn-cli

# Max tool-call rounds before the agent gives up.
GMGN_LOCAL_MAX_ITERS=6

# Cap generation per turn. Stops a small model from spiralling into a runaway
# tool-call JSON that fills the context (which makes llama.cpp 500).
GMGN_LOCAL_MAX_TOKENS=1024

# Truncate each tool result before feeding it back (GMGN JSON can be large).
GMGN_LOCAL_MAX_TOOL_RESULT_CHARS=4000

# Per-call gmgn-cli timeout (ms).
GMGN_CLI_TIMEOUT_MS=30000
